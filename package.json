{
  "name": "vscode-md-browser",
  "displayName": "Markdown Browser",
  "description": "Open links from markdown files in an embedded browser within VS Code",
  "version": "0.1.0",
  "publisher": "jrjfonseca",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jrjfonseca/vscode-md-browser.git"
  },
  "license": "MIT",
  "categories": ["Other"],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "md-browser.openUrl",
        "title": "Open Link in Embedded Browser"
      },
      {
        "command": "md-browser.openUrlExternal",
        "title": "Open Link in System Browser"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "md-browser.openUrl",
          "when": "editorLangId == markdown",
          "group": "navigation@1"
        },
        {
          "command": "md-browser.openUrlExternal",
          "when": "editorLangId == markdown",
          "group": "navigation@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "md-browser.openUrl",
        "key": "alt+enter",
        "when": "editorLangId == markdown && editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
